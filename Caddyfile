fruitdet.ru, www.fruitdet.ru {
    encode gzip

    request_body {
        max_size 20MB
    }

    reverse_proxy model-api:5000 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}

        transport http {
            read_timeout 300s
            write_timeout 300s
            dial_timeout 30s
        }
    }
}
